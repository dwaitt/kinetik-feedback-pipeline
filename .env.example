# BDR Feedback Digest - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env or key.env to version control.

# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Absolute path to the root feedback folder.
# This folder should contain: Forms/, Partner Notes/, Transcripts/
# Windows example: BASE_DIR=C:\Users\YourName\OneDrive\FeedbackFolder
# Mac/Linux example: BASE_DIR=/Users/yourname/feedback
BASE_DIR=/path/to/your/feedback/folder
